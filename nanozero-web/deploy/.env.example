# Copier en .env (dans ce dossier) et ajuster. Lu par docker-compose.yml.
# Le .env réel n'est PAS versionné (cf. .gitignore).

# Mot de passe PostgreSQL (service postgres + URL de connexion du jobserver). OBLIGATOIRE.
POSTGRES_PASSWORD=change-me-strong-password

# Auth API du jobserver. VIDE = auth désactivée → contribution publique ouverte
# (anyone peut claim/submit ; l'anti-poison est la drift detection Epic D, pas l'auth).
# Mettre une valeur seulement si tu veux fermer l'API (casserait la contribution publique).
JOBSERVER_API_KEY=

# Objectif de la jauge collective « Ensemble vers gen-N+1 » (positions vérifiées de la saison).
SEASON_TARGET=20000000

# Fenêtre de rétention HOT (BLOBs). 2 = ce que lit le training. Garder bas (disque 96 Go).
FLUSH_RETENTION_WINDOW=2

# Seuil de flush NPZ (positions non-flushées par version avant un shard). 100000 en prod ;
# baisser ponctuellement (ex 50) pour valider le flusher avec peu de trafic.
FLUSH_THRESHOLD=100000

# --- Backend site (Spring Boot, D11) ---
# Version réseau imposée aux parties persistées (à synchroniser avec le champion promu).
NETWORK_VERSION=gen-031
# Base publique pour les liens de partie (/play/?game=...).
SITE_PUBLIC_BASE_URL=https://nanozero.org
